# MongoDB Atlas
MONGODB_URI=your_mongodb_uri
MONGODB_DB=meowmeowbeenz

# API server
PORT=8000
CORS_ORIGINS=http://localhost:4173,http://localhost:8081,exp://localhost:8081
JWT_SECRET=meowmeowbeenz-dev-secret-change-in-production
JWT_EXPIRE_HOURS=168

# MiniMax agent (optional)
MINIMAX_API_KEY=
MINIMAX_API_URL=https://api.minimax.io/v1/chat/completions
MINIMAX_MODEL=M2-her
MINIMAX_DISABLE_THINKING=1

# Gemini video analysis (optional)
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent
GEMINI_MODEL=gemini-1.5-flash

# LiveKit (optional)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Moss retrieval (optional)
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
MOSS_INDEX_NAME=cat-voice-moss
MOSS_TOP_K=6
MOSS_ALPHA=0.8
MOSS_QUERY_TIMEOUT_SECONDS=1.0
MOSS_AUTO_SEED_INDEX=1

# Voice worker startup mode: set to 1 to keep worker running with backend startup.
# Leave 0/unset for API-only; worker starts when /api/livekit-token is requested.
START_VOICE_WORKER=0
